VITE_API_URL=http://localhost:8081

# Google Sign-In: mismo ID que el cliente OAuth 2.0 "Aplicación web" en Google Cloud Console.
# Error origin_mismatch: en ese cliente OAuth añade en "Orígenes JavaScript autorizados" la URL
# exacta de la barra de direcciones (ej. http://localhost:5173 y http://localhost:5174 si cambia el puerto).
# Sin barra final. Opcional: http://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=408294359663-pihvunt5ou1h5nkul77du76vvlsq66d1.apps.googleusercontent.com

# reCAPTCHA v3: aquí va solo la CLAVE DE SITIO (pública) del panel de Google.
# No pegues la clave secreta — si api.js dice "Invalid site key", revisa que no estén intercambiadas.
# Debe ser la pareja de google.recaptcha.secret en ms-security (mismo registro en recaptcha/admin).
VITE_RECAPTCHA_SITE_KEY=6LdKs5AsAAAAAN0ftJq7myyHuCww8soRCp9wFCpd